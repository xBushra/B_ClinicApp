@model ClinicApp.ViewModels.PatientReadVM

@{
    ViewData["Title"] = $"Patient #{Model.Id}";
}

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-md-6">

            <div class="card shadow">

                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0">Patient Details</h3>
                </div>

                <div class="card-body">

                    <div class="mb-3">
                        <h6 class="text-muted">Patient ID</h6>
                        <p class="fs-5">@Model.Id</p>
                    </div>

                    <div class="mb-3">
                        <h6 class="text-muted">Patient Name</h6>
                            <p class="fs-5">@Model.Name</p>
                    </div>

                </div>

                <div class="card-footer text-end">

                    <a asp-action="Index" class="btn btn-secondary">
                        Back
                    </a>
@* 
                    <a asp-action="Edit"
                       asp-route-id="@Model.Id"
                       class="btn btn-warning">
                        Edit
                    </a> *@

                </div>

            </div>

        </div>

    </div>

</div>