@using Microsoft.AspNetCore.Identity

@inject SignInManager<AppUser> signInManager
@inject UserManager<AppUser> userManager

<ul class="navbar-nav">
    @if (signInManager.IsSignedIn(User))
    {
        <li class="navbar-text">
            @{
                var appUser = await userManager.GetUserAsync(User);
                var profilePictureUrl = appUser?.ProfilePictureUrl ?? "/images/profiles/default.webp";
            }
            <img src="@profilePictureUrl" width="24" height="24" class="rounded-circle" />
            Hello, @userManager.GetUserName(User)!
        </li>
        <li class="nav-item">
            <a class="nav-link text-dark" asp-area="" asp-controller="Auth" asp-action="Logout">Logout</a>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link text-dark" asp-area="" asp-controller="Auth" asp-action="Login">Login</a>
        </li>
    }
</ul>